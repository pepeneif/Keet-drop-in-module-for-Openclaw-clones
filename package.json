{
  "name": "keet-dropin-module",
  "version": "0.1.0",
  "description": "Keet P2P chat drop‑in for OpenClaw‑compatible agents (Nanobot, CoPaw/QwenPaw, Hermes‑agent, OpenClaw).",
  "main": "install_keet_dropin.sh",
  "bin": {
    "keet-dropin": "./install_keet_dropin.sh"
  },
  "scripts": {
    "install:keet": "bash ./install_keet_dropin.sh",
    "test:keet:key": "node ./Tests/01_generate_keet_key.js",
    "test:keet:room": "node ./Tests/02_room_invite_and_chat.js",
    "test:keet:room:create": "node ./Tests/02_room_invite_and_chat.js --create-only"
  },
  "dependencies": {
    "blind-pairing-core": "^2.10.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperswarm": "^4.17.0"
  },
  "keywords": [
    "keet",
    "p2p",
    "hypercore",
    "plugin",
    "openclaw",
    "nanobot",
    "copaw",
    "hermes-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pepeneif/keet-dropin-module.git"
  },
  "license": "MIT"
}
